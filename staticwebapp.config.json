{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/.auth/*",
      "/privacy.html",
      "/terms.html",
      "/auth-start.html",
      "/auth-end.html"
    ]
  },
  "routes": [
    {
      "route": "/privacy.html",
      "allowedRoles": [ "anonymous", "authenticated" ]
    },
    {
      "route": "/terms.html",
      "allowedRoles": [ "anonymous", "authenticated" ]
    },
    {
      "route": "/auth-start.html",
      "allowedRoles": [ "anonymous", "authenticated" ]
    },
    {
      "route": "/auth-end.html",
      "allowedRoles": [ "anonymous", "authenticated" ]
    },
    {
      "route": "/.auth/*",
      "allowedRoles": [ "anonymous", "authenticated" ]
    },
    {
      "route": "/*",
      "allowedRoles": [ "authenticated" ]
    }
  ],
  "responseOverrides": {
    "401": {
      "statusCode": 302,
      "redirect": "/.auth/login/aad"
    }
  }
}