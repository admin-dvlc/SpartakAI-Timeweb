{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/.auth/*",
      "/privacy.html",
      "/terms.html",
      "/auth-start.html",
      "/auth-end.html"
    ]
  },
  "routes": [
    {
      "route": "/privacy.html",
      "allowedRoles": [ "anonymous", "authenticated" ]
    },
    {
      "route": "/terms.html",
      "allowedRoles": [ "anonymous", "authenticated" ]
    },
    {
      "route": "/auth-start.html",
      "allowedRoles": [ "anonymous", "authenticated" ]
    },
    {
      "route": "/auth-end.html",
      "allowedRoles": [ "anonymous", "authenticated" ]
    },
    {
      "route": "/teams",
      "allowedRoles": [ "anonymous", "authenticated" ]
    },
    {
      "route": "/teams/*",
      "allowedRoles": [ "anonymous", "authenticated" ]
    },
    {
      "route": "/.auth/*",
      "allowedRoles": [ "anonymous", "authenticated" ]
    },
    {
      "route": "/*",
      "allowedRoles": [ "authenticated" ]
    }
  ]
}